# Path to the SQLite database file (created automatically on first run)
DATABASE_URL=./data/app.db

# Random secret used by better-auth to sign sessions — MUST be changed in production
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the app (used by better-auth for redirects and CSRF)
BETTER_AUTH_URL=http://localhost:3000
# Same value, exposed to the browser so the auth client calls the right endpoint.
# Must match BETTER_AUTH_URL exactly.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# URL path prefix when serving behind a reverse proxy at a subpath (no trailing slash).
# Must match the nginx location and BETTER_AUTH_URL path.
# Example: BASE_PATH=/calendyfind
# Leave unset (or empty) when serving at the root.
BASE_PATH=

# First admin account — created by `pnpm db:seed`
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# AES-256-GCM key for encrypting write-target credentials at rest — REQUIRED
# App refuses to start without a valid key. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Google Calendar OAuth 2.0 (Phase 4) ─────────────────────────────────────
# Required to connect Google Calendar as a write target.
# Create OAuth 2.0 credentials in Google Cloud Console → APIs & Services →
# Credentials → OAuth 2.0 Client IDs (type: Web application).
# Authorized redirect URI: {BETTER_AUTH_URL}/api/google-oauth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SMTP — iMIP invite emails (Phase 4) ─────────────────────────────────────
# Required for sending meeting invitations and cancellations to attendees.
# For best DKIM/SPF alignment and RSVP rendering, SMTP_FROM should share the
# same domain as the organizer's email address.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to true only for port 465 (implicit TLS); leave false for port 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address shown to attendees, e.g. "Bookings <bookings@example.com>"
SMTP_FROM=

# ─── Phase 6 — Rate limiting ─────────────────────────────────────────────────
# All optional; leave blank to use defaults (shown in comments).
# Horizontal scaling: replace the in-memory limiter with Redis for multi-instance.
RATE_LIMIT_SLOT_LIST_PER_MIN=60    # slot-list requests per IP per minute
RATE_LIMIT_HOLD_IP_PER_MIN=10      # hold requests per IP per minute
RATE_LIMIT_HOLD_EMAIL_PER_HOUR=5   # hold requests per IP+email per hour
RATE_LIMIT_HOLD_CONCURRENT=3       # concurrent live holds per IP+page
RATE_LIMIT_CONFIRM_PER_MIN=20      # confirm requests per IP per minute
RATE_LIMIT_CANCEL_PER_MIN=10       # cancel requests per IP per minute
RATE_LIMIT_LOGIN_PER_MIN=10        # login attempts per IP per minute

# ─── Phase 6 — Reminders ─────────────────────────────────────────────────────
# Comma-separated list of minutes before meeting start to send reminder emails.
# Default: 24h and 1h before.
REMINDER_OFFSETS_MIN=1440,60

# Secret for the manual reminder trigger endpoint POST /api/reminders/trigger
# Generate with: openssl rand -base64 32
REMINDER_SECRET=
